# Claude (Anthropic) — required for Phase 1+
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini (Google) — required for Phase 2+
GOOGLE_API_KEY=your_google_api_key_here

# Database — required for Phase 2+
DB_URL=postgresql://podium:password@localhost:5432/podium
DB_PASSWORD=change_this_password

# Whisper — required for Phase 2+
# Options: base, small, medium, large
WHISPER_MODEL=small

# App config
STREAMLIT_PORT=8501
N8N_PORT=5678
